PORT=3000

# Standard Node convention. Set to "production" for a real deployment — this
# drives: (1) RECONNECT_TOKEN_SECRET and ADMIN_API_KEY become required,
# (2) logs switch to plain newline-delimited JSON, (3) general production checks.
# Leave unset for local development.
NODE_ENV=

# Comma-separated list of origins allowed to connect (HTTP API + WebSocket).
# Defaults to http://localhost:3000 if unset.
# Production example: ALLOWED_ORIGINS=https://yourdomain.com
#
# Note: this server does not auto-load .env files — set these as real process
# environment variables at deploy time (PM2 env, systemd, or deploy/env.production).
ALLOWED_ORIGINS=http://localhost:3000

# HMAC signing secret for reconnect tokens. REQUIRED in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RECONNECT_TOKEN_SECRET=

# Optional: max reconnect token age in milliseconds (default 30 days).
# RECONNECT_TOKEN_MAX_AGE_MS=2592000000

# Bearer token for admin-panel writes and sensitive reads. REQUIRED in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=

# Path to the SQLite match-history database file. Defaults to match-history.db
# in the server's working directory. Use an absolute path in production, e.g.:
# DB_PATH=/var/lib/hidden-eleven/match-history.db
DB_PATH=
