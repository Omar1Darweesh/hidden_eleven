# Dependencies
node_modules/

# Build output (rebuilt on the server via `npm run build`)
dist/

# Environment secrets — never commit real .env, only .env.example
.env
.env.*
!.env.example

# Runtime data / logs — local dev artifacts, not part of the app
match-history.db
*.log

# Generated backup archives (BackupService) — regenerated on demand, never
# something to version-control.
backups/

# OS/editor cruft
.DS_Store
