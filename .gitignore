# Dependencies
node_modules/

# Build output (rebuilt on the server via `npm run build`)
dist/

# Environment secrets — never commit real .env, only .env.example
.env
.env.*
!.env.example

# Runtime data / logs — local dev artifacts, not part of the app
match-history.db
*.log

# Generated backup archives (BackupService) — regenerated on demand, never
# something to version-control.
backups/

# Stale, unused build output — the server serves the Flutter web build from
# the sibling ../hidden_eleven/build/web directory (see main.ts), never from
# a public/ folder inside this repo. This was dead weight left over from
# early local dev.
public/

# Machine-specific PM2 config (real production secrets — ADMIN_API_KEY,
# RECONNECT_TOKEN_SECRET) — never committed, set up manually per-server.
ecosystem.config.js
ecosystem.config.jsy

# OS/editor cruft
.DS_Store
